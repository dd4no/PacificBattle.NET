@page "/"
@using PacificBattle.CombatResolution
@using PacificBattle.Interfaces
@inject ILogger<BattleBox> logger
@inject IFleetManager fm

<div id="page">

    <div id="shipBox"class="p-1">

        @* Attacking Ships *@
        <div class="d-flex justify-content-around mt-4 pt-4 pb-4">
            @foreach (var ship in Aggressors)
            {   
                <button class="@(ship.Selected ? "selected" : "selectable")" @onclick="() => OnShipSelected(ship)">
                    <ShipTile Ship="ship"></ShipTile>
                </button>             
            }
        </div>

        @* Defending Ships *@
        <div class="d-flex justify-content-around mt-4 pt-4">
            @foreach (var ship in Defenders)
            {
                <button class="defender @(ship.Selected ? "selected" : "selectable")" @onclick="() => OnShipSelected(ship)">
                    <ShipTile Ship="ship"></ShipTile>
                </button>             
            }
        </div>
         
    </div>

    <div id="bottombox" class="d-flex">

        <div id="buttonbox" class="w-75 d-flex py-4">

            <div class="w-50 text-center p-1">
                <button class="app-button" @onclick="GetShips"><b>Get Ships</b></button>
            </div>

            <div class="d-flex w-50">
                <div class="w-50 text-center p-1">
                    <button id="selectButton" class="app-button" hidden="@_selecting" @onclick="StartSelecting"><b>Select Ships</b></button>
                </div>

                <div class="w-50 text-center p-1">
                    <button id="startButton" class="app-button" hidden="@(!_selecting)" @onclick="ResolveCombat"><b>Start Battle</b></button>
                </div>
            </div>

        </div>

        <div id="logbox" class="w-25">

            @* Combat Results *@
            <h4 class="text-center pt-1">Combat Log</h4>
            <CombatLog Messages="BattleLogs" />

        </div>

    </div>

</div>



 

