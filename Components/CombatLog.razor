<!-- Combat Log Component-->

<div id="messagebox" class="text-center pb-2">

    @foreach (var message in Messages)
    {
        <h6>@message</h6>
    }

</div>

<style>
    #messagebox {
        height: 92%;
        width: 100%;
        margin: 0 auto;
        margin-top: .75rem;
        padding: .5rem;
        border: 1px solid black;
        border-radius: 15px;
        overflow-y: auto;
        background-color: antiquewhite;
    }
</style>

@code 
{
    [Parameter] public List<string> Messages { get; set; } = [];
}
